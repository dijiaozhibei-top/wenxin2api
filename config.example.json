{
  "_comment": "Wenxin2API 配置文件示例 - 复制为 config.json 使用",
  "_doc": "文档: https://github.com/dijiaozhibei-top/ds2api (改造为文心)",
  "keys": [
    "your-api-key-1",
    "your-api-key-2"
  ],
  "api_keys": [
    {
      "key": "your-api-key-1",
      "name": "主 API Key",
      "remark": "给 OpenAI 客户端使用"
    },
    {
      "key": "your-api-key-2",
      "name": "备用 API Key",
      "remark": "压测或临时调试"
    }
  ],
  "accounts": [
    {
      "_comment": "使用 chat_token 方式（推荐）",
      "name": "主账号",
      "remark": "从浏览器抓包获取 chat_token",
      "chat_token": "从 chat.baidu.com 抓包获取的 chat_token"
    },
    {
      "_comment": "使用 token 字段（兼容旧格式）",
      "name": "备用账号",
      "token": "your-chat-token-alternative"
    }
  ],
  "model_aliases": {
    "gpt-4o": "deepseek-v4",
    "gpt-5.5": "deepseek-v4",
    "gpt-5.3-codex": "deepseek-v4-pro",
    "o3": "deepseek-v4-pro"
  },
  "responses": {
    "store_ttl_seconds": 900
  },
  "current_input_file": {
    "enabled": true,
    "min_chars": 0
  },
  "thinking_injection": {
    "enabled": true,
    "prompt": ""
  },
  "embeddings": {
    "provider": "deterministic"
  },
  "admin": {
    "jwt_expire_hours": 24
  },
  "runtime": {
    "account_max_inflight": 2,
    "account_max_queue": 0,
    "global_max_inflight": 0,
    "token_refresh_interval_hours": 6
  },
  "auto_delete": {
    "mode": "none"
  }
}
