{
  "client": {
    "name": "BaiduWenxin_PC",
    "platform": "web",
    "version": "1.0.0",
    "android_api_level": "",
    "locale": "zh_CN"
  },
  "base_headers": {
    "Accept": "text/event-stream",
    "Content-Type": "application/json",
    "accept-language": "zh-CN,zh;q=0.9,en;q=0.8,en-GB;q=0.7,en-US;q=0.6",
    "isDeepseek": "1",
    "source": "pc_csaitab",
    "landingPageSwitch": "",
    "personifiedSwitch": "0"
  },
  "skip_contains_patterns": [
    "speedInfo",
    "costs",
    "typing",
    "theme",
    "userInfo",
    "logInfo",
    "cacheStatus"
  ],
  "skip_exact_paths": []
}
